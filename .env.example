# --- Mock Client server ---
MOCK_CLIENT_PORT=8088
MOCK_CLIENT_LOG_LEVEL=INFO
MOCK_CLIENT_LOG_FORMAT=auto
MOCK_CLIENT_URL_PATH_PREFIX=/transcribe-svc-mock-tool
# Optional UI section toggles; default to true when unset.
MOCK_CLIENT_SHOW_MOCK_LIVE_CHAT=true
MOCK_CLIENT_SHOW_SCENARIO_TESTS=true
MOCK_CLIENT_SHOW_CONCURRENT_LOAD_TEST=true

# --- WebSocket target (Realtime Transcribe Service) ---
MOCK_CLIENT_DEFAULT_WS_URL=ws://127.0.0.1:8080/transcribe-svc/ws/v1/realtime-transcriptions

# --- Kafka (mock-tool only; not shared with transcribe-service env names) ---
MOCK_CLIENT_KAFKA_BOOTSTRAP=127.0.0.1:9092
MOCK_CLIENT_KAFKA_TOPIC=AI_STAGING_TRANSCRIPTION
# local = PLAINTEXT (docker-compose). aws_msk = MSK IAM (SASL_SSL + OAUTHBEARER).
MOCK_CLIENT_KAFKA_MODE=local

# Required when MOCK_CLIENT_KAFKA_MODE=aws_msk (MSK IAM token signing).
# MOCK_CLIENT_KAFKA_AWS_REGION=ap-east-1

# Optional custom CA bundle for broker TLS:
# MOCK_CLIENT_KAFKA_SSL_CA_FILE=

# Optional: enable AWS MSK debug credentials for MSK IAM token signing.
# MOCK_CLIENT_KAFKA_AWS_DEBUG_CREDS=false

# --- Auth (mock client JWT for outbound WS/HTTP) ---
AUTH_ENABLED=false
# Optional: explicit Bearer token. If empty, the mock client will try
# MOCK_CLIENT_AUTH_SIGNING_MATERIAL.
MOCK_CLIENT_AUTH_TOKEN=
# Optional: HS256 signing material used to auto-generate a long-lived JWT locally.
MOCK_CLIENT_AUTH_SIGNING_MATERIAL=
# Subject claim used when the mock client auto-generates a JWT.
MOCK_CLIENT_AUTH_SUBJECT=mock-client
# Token lifetime in days for locally generated mock-client JWTs.
MOCK_CLIENT_AUTH_TTL_DAYS=30
