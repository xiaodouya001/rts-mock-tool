# Mock Client server process
MOCK_CLIENT_HOST=0.0.0.0
MOCK_CLIENT_PORT=8088
MOCK_CLIENT_LOG_LEVEL=INFO
MOCK_CLIENT_LOG_FORMAT=auto

# Mock Client UI defaults
MOCK_CLIENT_DEFAULT_WS_URL=ws://127.0.0.1:8080/ws/v1/realtime-transcriptions
# Whether the mock client should resolve or generate Authorization: Bearer <JWT>.
AUTH_ENABLED=false
# Optional: explicit Bearer token. If empty, the mock client will try
# MOCK_CLIENT_AUTH_SIGNING_MATERIAL.
MOCK_CLIENT_AUTH_TOKEN=
# Optional: HS256 signing material used to auto-generate a long-lived JWT locally.
MOCK_CLIENT_AUTH_SIGNING_MATERIAL=
# Subject claim used when the mock client auto-generates a JWT.
MOCK_CLIENT_AUTH_SUBJECT=mock-client
# Token lifetime in days for locally generated mock-client JWTs.
MOCK_CLIENT_AUTH_TTL_DAYS=30
MOCK_CLIENT_DEFAULT_KAFKA_BOOTSTRAP=127.0.0.1:9092
MOCK_CLIENT_DEFAULT_KAFKA_TOPIC=AI_STAGING_TRANSCRIPTION
